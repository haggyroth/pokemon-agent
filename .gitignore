# Virtual environment
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# Compiled libmgba binding (built locally via: python -m game._mgba_build)
game/_mgba_native.c
game/_mgba_native*.o
game/_mgba_native*.so

# Environment variables (contains local paths and config)
.env

# Personal game data — gitignored, directory preserved via .gitkeep
logs/*.json
logs/*.jsonl
logs/*.log
logs/*.bak
logs/eval/

# Save states (binary, machine-specific)
saves/*
!saves/.gitkeep

# Screenshots captured during agent runs
*.png

# Claude Code local settings
.claude/settings.local.json

# IDE
.vscode/
.idea/

# Internal dev notes
BUILD_PLAN.md

# Windows
Thumbs.db
Desktop.ini

# macOS
.DS_Store
