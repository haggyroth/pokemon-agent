# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── mGBA-http server ──────────────────────────────────────────────────────────
# Change only if you moved it off the default port.
MGBA_HTTP_BASE=http://localhost:5000

# ── LM Studio inference server ────────────────────────────────────────────────
LM_STUDIO_BASE=http://localhost:1234/v1

# ── Model ─────────────────────────────────────────────────────────────────────
# Must match the model name exactly as shown in LM Studio.
# Examples:
#   qwen/qwen3-14b                  (Qwen3 — set ENABLE_THINKING=true)
#   qwen/qwen2.5-14b-instruct       (Qwen2.5 — set ENABLE_THINKING=false)
#   lmstudio-community/llama-3.1-8b
MODEL_NAME=qwen/qwen2.5-14b-instruct

# ── LLM sampling ──────────────────────────────────────────────────────────────
TEMPERATURE=0.6
MAX_TOKENS=4096

# Set to true only for Qwen3 models that expose reasoning tokens.
ENABLE_THINKING=false

# ── Paths ─────────────────────────────────────────────────────────────────────
# Where mGBA saves the agent's screenshot each tick (Windows path).
SCREENSHOT_PATH=C:\mgba\agent_frame.png

# ── Timing ────────────────────────────────────────────────────────────────────
BUTTON_TAP_DELAY=0.10
DECISION_INTERVAL=1.00

# ── Reward ────────────────────────────────────────────────────────────────────
HP_HEAL_THRESHOLD=0.30
