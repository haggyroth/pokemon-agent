# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Emulator backend ──────────────────────────────────────────────────────────
# native: drive libmgba in-process (recommended; no GUI/Lua/mGBA-http).
#         Requires `brew install mgba` and `python -m game._mgba_build`.
# http:   legacy mGBA-http transport (mGBA GUI + Lua socket + .NET server).
MGBA_BACKEND=native
# Absolute path to the LeafGreen .gba ROM (native backend loads it directly).
ROM_PATH=~/mgba-http/Pokemon_LeafGreen.gba

# Watch the agent play in a live window (native backend; requires pygame).
SHOW_WINDOW=false
VIEWER_SCALE=3      # 240x160 * scale -> window size (3 = 720x480)
VIEWER_FPS=60       # playback cap; 0 = uncapped (full emulator speed)

# ── mGBA-http server (http backend only) ──────────────────────────────────────
# Change only if you moved it off the default port.
MGBA_HTTP_BASE=http://localhost:5000

# ── LM Studio inference server ────────────────────────────────────────────────
LM_STUDIO_BASE=http://localhost:1234/v1

# ── Model ─────────────────────────────────────────────────────────────────────
# Must match the model name exactly as shown in LM Studio.
# Examples:
#   qwen/qwen3-14b                  (Qwen3 — set ENABLE_THINKING=true)
#   qwen/qwen2.5-14b-instruct       (Qwen2.5 — set ENABLE_THINKING=false)
#   lmstudio-community/llama-3.1-8b
MODEL_NAME=qwen/qwen2.5-14b-instruct

# ── LLM sampling ──────────────────────────────────────────────────────────────
TEMPERATURE=0.6
# MAX_TOKENS caps the response (it doesn't force long output — the model stops
# when done). prompt + MAX_TOKENS must fit the model's *loaded* context window,
# or every call fails with "Context size exceeded". Reasoning models want more
# headroom (4096–8192) so the tool call isn't truncated; small-context builds
# need less. Check LM Studio's loaded context length.
MAX_TOKENS=4096

# Set to true only for reasoning models that expose reasoning_content/<think>.
ENABLE_THINKING=false

# ── Run control ───────────────────────────────────────────────────────────────
# USE_VISION: attach the live screenshot to the model. Set false for text-only
# models, or models with unstable vision (some crash/overflow on images).
USE_VISION=true
# START_FROM_SAVE: load a battery .sav and "Continue" into gameplay at startup
# (drives through title -> Continue -> skips the quest-log recap). Empty = boot
# the ROM as-is.
# START_FROM_SAVE=~/mgba-http/Pokemon_LeafGreen.sav
# START_FROM_STATE: load an mGBA save STATE (.ss*) directly — instant, no title/
# Continue/recap. Takes precedence over START_FROM_SAVE. Good for testing from a
# fixed spot, e.g. the Pallet Town exterior state generated in saves/.
# START_FROM_STATE=saves/pallet_exterior.ss1
# MAX_STEPS: stop after N decision steps (0 = run until interrupted).
MAX_STEPS=0

# ── Paths ─────────────────────────────────────────────────────────────────────
# Where mGBA-http saves the agent's screenshot each tick.
# Defaults to the OS temp directory (e.g. /tmp/mgba_agent_frame.png on
# macOS/Linux, %TEMP%\mgba_agent_frame.png on Windows).
# Override only if needed:
# SCREENSHOT_PATH=/tmp/mgba_agent_frame.png        # macOS / Linux
# SCREENSHOT_PATH=C:\mgba\agent_frame.png          # Windows

# ── Timing ────────────────────────────────────────────────────────────────────
BUTTON_TAP_DELAY=0.10
DECISION_INTERVAL=1.00

# ── Reward ────────────────────────────────────────────────────────────────────
HP_HEAL_THRESHOLD=0.30
